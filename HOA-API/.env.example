DATABASE_URL=postgresql://hoa:hoa_dev_password@localhost:5435/hoa_africa?schema=public
JWT_SECRET=hoa-africa-dev-jwt-secret-change-me
JWT_EXPIRES_IN=24h
CORS_ORIGIN=http://localhost:3002,http://localhost:3005
PORT=3003

# Front-end app URLs — used by emails (invitations, password reset) to
# build links the recipient clicks. Override per environment.
APP_ENTERPRISE_URL=http://localhost:3002
APP_RESIDENTS_URL=http://localhost:3005

# Phase 10.1 — Web Push (VAPID). Generate keys with:
#   node -e "const wp=require('web-push'); console.log(wp.generateVAPIDKeys());"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:notifications@hoa.africa

# --- LLM provider ---
# Precedence when LLM_PROVIDER is unset:
#   OPENAI_API_KEY > ANTHROPIC_API_KEY > mock
# Set LLM_PROVIDER to force one ('openai' | 'anthropic' | 'mock').
LLM_PROVIDER=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# --- Paystack (resident + platform billing) ---
# Required for real card / mobile-money charges. When absent, /payments/intents
# uses the mock-checkout dev path. Production deploys must set this.
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# --- Email (Resend) ---
# Every transactional + broadcast email routes through Resend via MailService.
# When RESEND_API_KEY is unset, the mock provider takes over and the EmailDelivery
# log still gets rows for dev parity (no external network calls).
# `MAIL_FROM` accepts either a bare address or "Display Name <addr@domain>".
# The default sender is the verified noreply@metasession.co inbox.
RESEND_API_KEY=
MAIL_FROM=HOA.africa <noreply@metasession.co>
# Optional: Resend webhook signing secret (Svix). When set, /api/mail/webhook
# verifies the signature before processing delivered/opened/bounced events.
RESEND_WEBHOOK_SECRET=

# --- Observability ---
# Sentry — leave SENTRY_DSN empty to disable.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_RELEASE=

# PostHog — leave POSTHOG_API_KEY empty to disable.
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Prometheus /metrics — if set, scrapes must send `Authorization: Bearer <value>`.
METRICS_BEARER=

# --- File storage (Phase 1.5) ---
# Local-disk storage root. On Railway, mount a Volume and set this to /data/storage.
STORAGE_ROOT=./storage
# Separate secret for signed download URLs (falls back to JWT_SECRET in dev).
STORAGE_URL_SECRET=
