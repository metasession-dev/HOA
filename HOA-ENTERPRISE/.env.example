NEXT_PUBLIC_API_URL=http://localhost:3003
PORT=3002

# Cross-app URLs used by the topbar role switcher to hand off the JWT when
# a user with multiple roles flips between admin and resident contexts.
NEXT_PUBLIC_ENTERPRISE_URL=http://localhost:3002
NEXT_PUBLIC_RESIDENTS_URL=http://localhost:3005

# Marketing site URL — used by the auth pages' "Back to hoa.africa" link.
# Leave empty in dev to hide the link entirely.
NEXT_PUBLIC_MARKETING_URL=http://localhost:8080

# Observability — leave empty to disable.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENV=
NEXT_PUBLIC_SENTRY_RELEASE=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
