# Why this file exists:
#
# @nestjs/apollo@13.x declares a peer dependency on @nestjs/common@^11.0.1.
# We track @nestjs/common@11.1.x to pull in security + maintenance fixes,
# which trips npm v10's strict peer-dependency resolver. Plain `npm ci`
# fails with ERESOLVE in Railway's build container even though the runtime
# behaviour is fine — @nestjs/common is forward-compatible within v11.
#
# Setting `legacy-peer-deps=true` here is the documented escape hatch,
# applied at the directory level so EVERY npm invocation in this app
# (install, ci, audit, fund) sees it consistently. The flag does NOT
# affect production behaviour — only the resolver.
#
# Drop this file the day @nestjs/apollo widens its peer range or we drop
# back to @nestjs/common@^11.0.
legacy-peer-deps=true
