# Why this file exists:
#
# `lovable-tagger` declares React-18 peer deps that trip npm's strict
# peer-dependency resolver, so a plain `npm install` / `npm ci` fails with
# ERESOLVE in clean build containers (Railway previously, Cloudflare Pages
# now). Setting `legacy-peer-deps=true` at the directory level makes EVERY
# npm invocation tolerate it consistently — this replaces the need to pass
# `--legacy-peer-deps` on the command line or set an NPM_FLAGS env var in
# the Cloudflare Pages dashboard. The flag only affects resolution, not
# runtime behaviour.
#
# Drop this file the day lovable-tagger widens its peer range.
legacy-peer-deps=true
